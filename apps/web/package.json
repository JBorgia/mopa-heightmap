{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -k -n api,web -c blue,green \"pnpm:start:api\" \"pnpm:start:web\"",
    "start:api": "cd ..\\.. && .venv\\Scripts\\python.exe -m uvicorn apps.api.main:app --reload --port 8000",
    "start:web": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "check:angular-version": "node scripts/check-angular-version.mjs",
    "generate:openapi": "..\\..\\.venv\\Scripts\\python.exe -m apps.api.export_openapi",
    "generate:api-types": "openapi-typescript openapi.json -o src/app/core/api/generated/api.d.ts",
    "sync:api-types": "pnpm run generate:openapi && pnpm run generate:api-types",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@primeng/themes": "^21.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "jsdom": "^28.0.0",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
